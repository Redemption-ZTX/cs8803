#!/bin/bash
# Experiment Lane:
# SNAPSHOT-026 Path C (warm-start):
# - remove all per-step shaping
# - reward only sparse goal + event-based shot/tackle/clearance signals
# - warm-start from BC->MAPPO champion checkpoint-2100

#SBATCH -J soccer-exp-mappo-libC
#SBATCH -A ece
#SBATCH -p coe-gpu
#SBATCH --qos=coe-ice
#SBATCH -N 1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=100G
#SBATCH -t 06:00:00
#SBATCH -o /home/hice1/wsun377/Desktop/cs8803drl/docs/experiments/artifacts/slurm-logs/soccer-exp-mappo-libC-%j.out

set -euo pipefail

cd /home/hice1/wsun377/Desktop/cs8803drl

PYTHON_BIN=/home/hice1/wsun377/.venvs/soccertwos_h100/bin/python

export PYTHONPATH=$PWD${PYTHONPATH:+:$PYTHONPATH}
export QUIET_CONSOLE=${QUIET_CONSOLE:-0}

unset RESTORE_CHECKPOINT
unset TEAMMATE_CHECKPOINT
unset TEAMMATE_BASE_CHECKPOINT
unset BC_WARMSTART_CHECKPOINT

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1

export WARMSTART_CHECKPOINT=${WARMSTART_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_vs_baseline_shaping_v2_bc_player_512x512_main_rerun2/MAPPOVsBaselineTrainer_Soccer_e53af_00000_0_2026-04-14_21-46-18/checkpoint_002100/checkpoint-2100}

export RUN_NAME=${RUN_NAME:-PPO_mappo_liberation_C_warm_bc2100_512x512_$(date +%Y%m%d_%H%M%S)}
export NUM_GPUS=${NUM_GPUS:-1}
export NUM_WORKERS=${NUM_WORKERS:-8}
export NUM_ENVS_PER_WORKER=${NUM_ENVS_PER_WORKER:-5}
export FCNET_HIDDENS=${FCNET_HIDDENS:-512,512}
export ROLLOUT_FRAGMENT_LENGTH=${ROLLOUT_FRAGMENT_LENGTH:-1000}
export NUM_SGD_ITER=${NUM_SGD_ITER:-4}
export SGD_MINIBATCH_SIZE=${SGD_MINIBATCH_SIZE:-2048}
export LR=${LR:-0.0001}
export CLIP_PARAM=${CLIP_PARAM:-0.15}

export USE_REWARD_SHAPING=${USE_REWARD_SHAPING:-1}
export SHAPING_TIME_PENALTY=${SHAPING_TIME_PENALTY:-0.0}
export SHAPING_BALL_PROGRESS=${SHAPING_BALL_PROGRESS:-0.0}
export SHAPING_GOAL_PROXIMITY_SCALE=${SHAPING_GOAL_PROXIMITY_SCALE:-0.0}
export SHAPING_OPP_PROGRESS_PENALTY=${SHAPING_OPP_PROGRESS_PENALTY:-0.0}
export SHAPING_POSSESSION_BONUS=${SHAPING_POSSESSION_BONUS:-0.0}
export SHAPING_POSSESSION_DIST=${SHAPING_POSSESSION_DIST:-1.25}
export SHAPING_PROGRESS_REQUIRES_POSSESSION=${SHAPING_PROGRESS_REQUIRES_POSSESSION:-0}
export SHAPING_DEEP_ZONE_OUTER_THRESHOLD=${SHAPING_DEEP_ZONE_OUTER_THRESHOLD:--8}
export SHAPING_DEEP_ZONE_OUTER_PENALTY=${SHAPING_DEEP_ZONE_OUTER_PENALTY:-0.0}
export SHAPING_DEEP_ZONE_INNER_THRESHOLD=${SHAPING_DEEP_ZONE_INNER_THRESHOLD:--12}
export SHAPING_DEEP_ZONE_INNER_PENALTY=${SHAPING_DEEP_ZONE_INNER_PENALTY:-0.0}
export SHAPING_DEFENSIVE_SURVIVAL_THRESHOLD=${SHAPING_DEFENSIVE_SURVIVAL_THRESHOLD:-0.0}
export SHAPING_DEFENSIVE_SURVIVAL_BONUS=${SHAPING_DEFENSIVE_SURVIVAL_BONUS:-0.0}
export SHAPING_FAST_LOSS_THRESHOLD_STEPS=${SHAPING_FAST_LOSS_THRESHOLD_STEPS:-0}
export SHAPING_FAST_LOSS_PENALTY_PER_STEP=${SHAPING_FAST_LOSS_PENALTY_PER_STEP:-0.0}

export SHAPING_EVENT_SHOT_REWARD=${SHAPING_EVENT_SHOT_REWARD:-0.05}
export SHAPING_EVENT_TACKLE_REWARD=${SHAPING_EVENT_TACKLE_REWARD:-0.03}
export SHAPING_EVENT_CLEARANCE_REWARD=${SHAPING_EVENT_CLEARANCE_REWARD:-0.03}
export SHAPING_EVENT_COOLDOWN_STEPS=${SHAPING_EVENT_COOLDOWN_STEPS:-10}
export SHAPING_SHOT_X_THRESHOLD=${SHAPING_SHOT_X_THRESHOLD:-10.0}
export SHAPING_SHOT_BALL_DX_MIN=${SHAPING_SHOT_BALL_DX_MIN:-0.5}
export SHAPING_CLEARANCE_FROM_X=${SHAPING_CLEARANCE_FROM_X:--8.0}
export SHAPING_CLEARANCE_TO_X=${SHAPING_CLEARANCE_TO_X:--4.0}

export TIMESTEPS_TOTAL=${TIMESTEPS_TOTAL:-12000000}
export MAX_ITERATIONS=${MAX_ITERATIONS:-300}
export TIME_TOTAL_S=${TIME_TOTAL_S:-14400}
export CHECKPOINT_FREQ=${CHECKPOINT_FREQ:-10}

export EVAL_INTERVAL=${EVAL_INTERVAL:-10}
export EVAL_EPISODES=${EVAL_EPISODES:-50}
export EVAL_BASE_PORT=${EVAL_BASE_PORT:-61405}
export EVAL_MAX_STEPS=${EVAL_MAX_STEPS:-1500}
export EVAL_OPPONENTS=${EVAL_OPPONENTS:-baseline,random}
export EVAL_TEAM0_MODULE=${EVAL_TEAM0_MODULE:-cs8803drl.deployment.trained_shared_cc_agent}
export EVAL_PYTHON_BIN=${EVAL_PYTHON_BIN:-$PYTHON_BIN}

export BASE_PORT=${BASE_PORT:-61505}
export LOG_LEVEL=${LOG_LEVEL:-INFO}
export LOG_SYS_USAGE=${LOG_SYS_USAGE:-0}

$PYTHON_BIN -u -m cs8803drl.training.train_ray_mappo_vs_baseline 2>&1
