#!/bin/bash
# Experiment Lane:
# SNAPSHOT-029 Path C:
# - warm-start from 025b@80 (current SOTA)
# - v2 shaping (no change from 025b base)
# - 025b tight PPO params
# - opponent pool: baseline 40% / 017@2100 20% / 024@270 20% / 025b@80-self 20%
# Tests H3: does training against peers give defense-vs-exploit robustness?

#SBATCH -J soccer-exp-029C-oppool-peers
#SBATCH -A ece
#SBATCH -p coe-gpu
#SBATCH --qos=coe-ice
#SBATCH -N 1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=100G
#SBATCH -t 08:00:00
#SBATCH -o /home/hice1/wsun377/Desktop/cs8803drl/docs/experiments/artifacts/slurm-logs/soccer-exp-029C-oppool-peers-%j.out

set -euo pipefail

cd /home/hice1/wsun377/Desktop/cs8803drl

PYTHON_BIN=/home/hice1/wsun377/.venvs/soccertwos_h100/bin/python

export PYTHONPATH=$PWD${PYTHONPATH:+:$PYTHONPATH}
export QUIET_CONSOLE=${QUIET_CONSOLE:-0}

unset BC_WARMSTART_CHECKPOINT
unset RESTORE_CHECKPOINT
unset TEAMMATE_CHECKPOINT
unset TEAMMATE_BASE_CHECKPOINT

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1

export RUN_NAME=${RUN_NAME:-PPO_mappo_029C_025b80_oppool_peers_512x512_$(date +%Y%m%d_%H%M%S)}
export NUM_GPUS=${NUM_GPUS:-1}
export NUM_WORKERS=${NUM_WORKERS:-8}
export NUM_ENVS_PER_WORKER=${NUM_ENVS_PER_WORKER:-5}
export FCNET_HIDDENS=${FCNET_HIDDENS:-512,512}
export ROLLOUT_FRAGMENT_LENGTH=${ROLLOUT_FRAGMENT_LENGTH:-1000}

# 025b tight PPO params (opponent_pool script defaulted to sgd_iter=10; override)
export NUM_SGD_ITER=${NUM_SGD_ITER:-4}
export SGD_MINIBATCH_SIZE=${SGD_MINIBATCH_SIZE:-2048}
export LR=${LR:-0.0001}
export CLIP_PARAM=${CLIP_PARAM:-0.15}

# warm-start from 025b@80 (current SOTA)
export WARMSTART_CHECKPOINT=${WARMSTART_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_field_role_binding_bc2100_stable_512x512_20260417_060418/MAPPOVsBaselineTrainer_Soccer_da95d_00000_0_2026-04-17_06-04-42/checkpoint_000080/checkpoint-80}

# opponent pool composition (reusing the 4-slot schema):
#   baseline 40% (hard-coded)
#   anchor  = 017@2100    (20%)
#   v1      = 024@270     (20%)
#   bs0     = 025b@80-self (20%)
export POOL_ANCHOR_CHECKPOINT=${POOL_ANCHOR_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_vs_baseline_shaping_v2_bc_player_512x512_main_rerun2/MAPPOVsBaselineTrainer_Soccer_e53af_00000_0_2026-04-14_21-46-18/checkpoint_002100/checkpoint-2100}
export POOL_V1_CHECKPOINT=${POOL_V1_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_field_role_binding_v2_warm470_512x512_20260416_045516/MAPPOVsBaselineTrainer_Soccer_0aab8_00000_0_2026-04-16_04-55-39/checkpoint_000270/checkpoint-270}
export POOL_BS0_CHECKPOINT=${POOL_BS0_CHECKPOINT:-$WARMSTART_CHECKPOINT}

export POOL_BASELINE_PROB=${POOL_BASELINE_PROB:-0.40}
export POOL_ANCHOR_PROB=${POOL_ANCHOR_PROB:-0.20}
export POOL_V1_PROB=${POOL_V1_PROB:-0.20}
export POOL_BS0_PROB=${POOL_BS0_PROB:-0.20}

# disable field-role binding (029C tests pool alone)
export SHAPING_FIELD_ROLE_BINDING=${SHAPING_FIELD_ROLE_BINDING:-0}

# v2 shaping (same as 025b base config)
export USE_REWARD_SHAPING=${USE_REWARD_SHAPING:-1}
export SHAPING_TIME_PENALTY=${SHAPING_TIME_PENALTY:-0.001}
export SHAPING_BALL_PROGRESS=${SHAPING_BALL_PROGRESS:-0.01}
export SHAPING_OPP_PROGRESS_PENALTY=${SHAPING_OPP_PROGRESS_PENALTY:-0.01}
export SHAPING_POSSESSION_BONUS=${SHAPING_POSSESSION_BONUS:-0.002}
export SHAPING_POSSESSION_DIST=${SHAPING_POSSESSION_DIST:-1.25}
export SHAPING_PROGRESS_REQUIRES_POSSESSION=${SHAPING_PROGRESS_REQUIRES_POSSESSION:-0}
export SHAPING_DEEP_ZONE_OUTER_THRESHOLD=${SHAPING_DEEP_ZONE_OUTER_THRESHOLD:--8}
export SHAPING_DEEP_ZONE_OUTER_PENALTY=${SHAPING_DEEP_ZONE_OUTER_PENALTY:-0.003}
export SHAPING_DEEP_ZONE_INNER_THRESHOLD=${SHAPING_DEEP_ZONE_INNER_THRESHOLD:--12}
export SHAPING_DEEP_ZONE_INNER_PENALTY=${SHAPING_DEEP_ZONE_INNER_PENALTY:-0.003}

# explicitly disable PBRS (this is v2, not PBRS)
export SHAPING_GOAL_PROXIMITY_SCALE=${SHAPING_GOAL_PROXIMITY_SCALE:-0.0}

export TIMESTEPS_TOTAL=${TIMESTEPS_TOTAL:-12000000}
export MAX_ITERATIONS=${MAX_ITERATIONS:-300}
export TIME_TOTAL_S=${TIME_TOTAL_S:-20000}
export CHECKPOINT_FREQ=${CHECKPOINT_FREQ:-10}

export EVAL_INTERVAL=${EVAL_INTERVAL:-10}
export EVAL_EPISODES=${EVAL_EPISODES:-50}
export EVAL_BASE_PORT=${EVAL_BASE_PORT:-62605}
export EVAL_MAX_STEPS=${EVAL_MAX_STEPS:-1500}
export EVAL_OPPONENTS=${EVAL_OPPONENTS:-baseline,random}
export EVAL_TEAM0_MODULE=${EVAL_TEAM0_MODULE:-cs8803drl.deployment.trained_shared_cc_agent}
export EVAL_PYTHON_BIN=${EVAL_PYTHON_BIN:-$PYTHON_BIN}

export BASE_PORT=${BASE_PORT:-62705}
export LOG_LEVEL=${LOG_LEVEL:-INFO}
export LOG_SYS_USAGE=${LOG_SYS_USAGE:-0}

$PYTHON_BIN - <<'PY'
import os
import socket
import sys
import torch

num_gpus = int(os.environ.get("NUM_GPUS", "0"))
if num_gpus > 0 and not torch.cuda.is_available():
    host = socket.gethostname()
    visible = os.environ.get("CUDA_VISIBLE_DEVICES", "")
    sys.stderr.write(
        "GPU preflight failed: NUM_GPUS>0 but torch.cuda.is_available() is False.\n"
        f"hostname={host}\n"
        f"CUDA_VISIBLE_DEVICES={visible!r}\n"
        "Run this batch inside an active GPU allocation (srun/salloc) or submit it with sbatch.\n"
    )
    raise SystemExit(3)
print(
    f"[gpu-preflight] host={socket.gethostname()} cuda_available={torch.cuda.is_available()} "
    f"device_count={torch.cuda.device_count()} cuda_visible={os.environ.get('CUDA_VISIBLE_DEVICES', '')!r}"
)
PY

$PYTHON_BIN -u -m cs8803drl.training.train_ray_mappo_vs_opponent_pool 2>&1
