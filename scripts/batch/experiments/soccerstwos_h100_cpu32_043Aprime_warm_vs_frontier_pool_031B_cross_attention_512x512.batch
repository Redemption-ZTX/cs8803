#!/bin/bash
# Experiment Lane:
# SNAPSHOT-043A':
# - 031B@1220 warm-start + cross-attention architecture unchanged
# - baseline/diversity curriculum instead of single frozen strong opponent
# - opponent pool: baseline 50% + frozen frontier {031A 20%, 029B 15%, 036D 15%}
# - distinct from 046E intensity line: this is diversity/generalization, not
#   one-opp pressure training

#SBATCH -J soccer-exp-043Ap
#SBATCH -A ece
#SBATCH -p coe-gpu
#SBATCH --qos=coe-ice
#SBATCH -N 1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=100G
#SBATCH -t 12:00:00
#SBATCH -o /home/hice1/wsun377/Desktop/cs8803drl/docs/experiments/artifacts/slurm-logs/soccer-exp-043Ap-%j.out

set -euo pipefail

cd /home/hice1/wsun377/Desktop/cs8803drl

PYTHON_BIN=/home/hice1/wsun377/.venvs/soccertwos_h100/bin/python

export PYTHONPATH=$PWD${PYTHONPATH:+:$PYTHONPATH}
export QUIET_CONSOLE=${QUIET_CONSOLE:-0}

_RESTORE_OVERRIDE="${RESTORE_CHECKPOINT:-}"
unset RESTORE_CHECKPOINT
unset BC_WARMSTART_CHECKPOINT
unset TEAMMATE_CHECKPOINT
unset TEAMMATE_BASE_CHECKPOINT
unset TEAM_OPPONENT_CHECKPOINT
unset AUX_TEAM_ACTION_HEAD
unset AUX_TEAM_ACTION_WEIGHT
unset AUX_TEAM_ACTION_HIDDEN
[[ -n "$_RESTORE_OVERRIDE" ]] && export RESTORE_CHECKPOINT="$_RESTORE_OVERRIDE"

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1

PORT_SEED=${PORT_SEED:-${SLURM_JOB_ID:-$$}}
PORT_OFFSET=$(( (PORT_SEED % 60) * 50 ))

export WARMSTART_CHECKPOINT=${WARMSTART_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/031B_team_cross_attention_scratch_v2_resume1080/TeamVsBaselineShapingPPOTrainer_Soccer_cd2d4_00000_0_2026-04-19_05-47-38/checkpoint_001220/checkpoint-1220}

if [[ -z "${OPPONENT_POOL_FRONTIER_SPECS:-}" ]]; then
  export OPPONENT_POOL_FRONTIER_SPECS="031A|team_ray|0.20|/home/hice1/wsun377/Desktop/cs8803drl/ray_results/031A_team_dual_encoder_scratch_v2_512x512_20260418_054948/TeamVsBaselineShapingPPOTrainer_Soccer_fc02e_00000_0_2026-04-18_05-50-08/checkpoint_001040/checkpoint-1040;029B|shared_cc|0.15|/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_029B_bwarm170_to_v2_512x512_formal/MAPPOVsBaselineTrainer_Soccer_457ea_00000_0_2026-04-17_12-12-46/checkpoint_000190/checkpoint-190;036D|shared_cc|0.15|/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_036D_stable_learned_reward_on_029B190_512x512_20260418_124107/MAPPOVsBaselineTrainer_Soccer_72c1c_00000_0_2026-04-18_12-41-29/checkpoint_000150/checkpoint-150"
fi

export RUN_NAME=${RUN_NAME:-043Aprime_warm_vs_frontier_pool_031B_cross_attention_512x512_$(date +%Y%m%d_%H%M%S)}
export RAY_ADDRESS_OVERRIDE=${RAY_ADDRESS_OVERRIDE:-local}
export RAY_SESSION_TMPDIR_OVERRIDE=${RAY_SESSION_TMPDIR_OVERRIDE:-/tmp/r43Ap_${PORT_SEED}}
export NUM_GPUS=${NUM_GPUS:-1}
export NUM_WORKERS=${NUM_WORKERS:-8}
export NUM_ENVS_PER_WORKER=${NUM_ENVS_PER_WORKER:-3}
export FCNET_HIDDENS=${FCNET_HIDDENS:-512,512}

# 031B architecture
export TEAM_SIAMESE_ENCODER=${TEAM_SIAMESE_ENCODER:-1}
export TEAM_SIAMESE_ENCODER_HIDDENS=${TEAM_SIAMESE_ENCODER_HIDDENS:-256,256}
export TEAM_SIAMESE_MERGE_HIDDENS=${TEAM_SIAMESE_MERGE_HIDDENS:-256,128}
export TEAM_CROSS_ATTENTION=${TEAM_CROSS_ATTENTION:-1}
export TEAM_CROSS_ATTENTION_TOKENS=${TEAM_CROSS_ATTENTION_TOKENS:-4}
export TEAM_CROSS_ATTENTION_DIM=${TEAM_CROSS_ATTENTION_DIM:-64}

export ROLLOUT_FRAGMENT_LENGTH=${ROLLOUT_FRAGMENT_LENGTH:-1000}
export TRAIN_BATCH_SIZE=${TRAIN_BATCH_SIZE:-24000}
export SGD_MINIBATCH_SIZE=${SGD_MINIBATCH_SIZE:-2048}
export NUM_SGD_ITER=${NUM_SGD_ITER:-4}
export LR=${LR:-0.0001}
export CLIP_PARAM=${CLIP_PARAM:-0.15}

# Keep BASELINE_PROB for backwards-compatible header/defaults; 043A' uses the
# explicit frontier pool vars below.
export BASELINE_PROB=${BASELINE_PROB:-1.0}
export OPPONENT_POOL_BASELINE_PROB=${OPPONENT_POOL_BASELINE_PROB:-0.50}

# v2 shaping, unchanged from 031B
export USE_REWARD_SHAPING=${USE_REWARD_SHAPING:-1}
export SHAPING_FIELD_ROLE_BINDING=${SHAPING_FIELD_ROLE_BINDING:-0}
export SHAPING_TIME_PENALTY=${SHAPING_TIME_PENALTY:-0.001}
export SHAPING_BALL_PROGRESS=${SHAPING_BALL_PROGRESS:-0.01}
export SHAPING_GOAL_PROXIMITY_SCALE=${SHAPING_GOAL_PROXIMITY_SCALE:-0.0}
export SHAPING_GOAL_PROXIMITY_GAMMA=${SHAPING_GOAL_PROXIMITY_GAMMA:-0.99}
export SHAPING_GOAL_CENTER_X=${SHAPING_GOAL_CENTER_X:-15.0}
export SHAPING_GOAL_CENTER_Y=${SHAPING_GOAL_CENTER_Y:-0.0}
export SHAPING_OPP_PROGRESS_PENALTY=${SHAPING_OPP_PROGRESS_PENALTY:-0.01}
export SHAPING_POSSESSION_BONUS=${SHAPING_POSSESSION_BONUS:-0.002}
export SHAPING_POSSESSION_DIST=${SHAPING_POSSESSION_DIST:-1.25}
export SHAPING_PROGRESS_REQUIRES_POSSESSION=${SHAPING_PROGRESS_REQUIRES_POSSESSION:-0}
export SHAPING_DEEP_ZONE_OUTER_THRESHOLD=${SHAPING_DEEP_ZONE_OUTER_THRESHOLD:-0}
export SHAPING_DEEP_ZONE_OUTER_PENALTY=${SHAPING_DEEP_ZONE_OUTER_PENALTY:-0}
export SHAPING_DEEP_ZONE_INNER_THRESHOLD=${SHAPING_DEEP_ZONE_INNER_THRESHOLD:-0}
export SHAPING_DEEP_ZONE_INNER_PENALTY=${SHAPING_DEEP_ZONE_INNER_PENALTY:-0}
export SHAPING_DEFENSIVE_SURVIVAL_THRESHOLD=${SHAPING_DEFENSIVE_SURVIVAL_THRESHOLD:-0}
export SHAPING_DEFENSIVE_SURVIVAL_BONUS=${SHAPING_DEFENSIVE_SURVIVAL_BONUS:-0}
export SHAPING_FAST_LOSS_THRESHOLD_STEPS=${SHAPING_FAST_LOSS_THRESHOLD_STEPS:-0}
export SHAPING_FAST_LOSS_PENALTY_PER_STEP=${SHAPING_FAST_LOSS_PENALTY_PER_STEP:-0}

# First-pass verdict budget
export TIMESTEPS_TOTAL=${TIMESTEPS_TOTAL:-12000000}
export MAX_ITERATIONS=${MAX_ITERATIONS:-500}
export TIME_TOTAL_S=${TIME_TOTAL_S:-43200}
export CHECKPOINT_FREQ=${CHECKPOINT_FREQ:-10}

export EVAL_INTERVAL=${EVAL_INTERVAL:-10}
export EVAL_EPISODES=${EVAL_EPISODES:-50}
export EVAL_BASE_PORT=${EVAL_BASE_PORT:-$((56305 + PORT_OFFSET))}
export EVAL_MAX_STEPS=${EVAL_MAX_STEPS:-1500}
export EVAL_OPPONENTS=${EVAL_OPPONENTS:-baseline,random}
export EVAL_TEAM0_MODULE=${EVAL_TEAM0_MODULE:-cs8803drl.deployment.trained_team_ray_agent}
export EVAL_PYTHON_BIN=${EVAL_PYTHON_BIN:-$PYTHON_BIN}

export BASE_PORT=${BASE_PORT:-$((56405 + PORT_OFFSET))}
export LOG_LEVEL=${LOG_LEVEL:-INFO}
export LOG_SYS_USAGE=${LOG_SYS_USAGE:-0}

$PYTHON_BIN -u -m cs8803drl.training.train_ray_team_vs_baseline_shaping 2>&1
