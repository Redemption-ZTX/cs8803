#!/bin/bash
# Experiment Lane:
# SNAPSHOT-041B: per-agent Stage 2 PBRS handoff on 036D@150 base.
# - Warmstart from 036D@150 (1000ep avg 0.843, max 0.860 — first per-agent
#   learned-reward base to exceed 029B@190 on 1000ep max)
# - KEEP 036D's learned reward (λ=0.003 + warmup10 + finite-check) ← double shaping test
# - ADD goal-proximity PBRS (same recipe as 026B@170 → 029B handoff direction)
# - Standard v2 shaping otherwise (same as 036D)
# - Test: does adding analytical PBRS on top of learned reward push 1000ep
#   from 0.860 to 0.87-0.88, mirroring per-agent 026B→029B's +2.6pp jump?
# - Mirror experiment to SNAPSHOT-040B (team-level Stage 2 on 031A@1040)

#SBATCH -J soccer-exp-041B-pbrs-on-036D150
#SBATCH -A ece
#SBATCH -p coe-gpu
#SBATCH --qos=coe-ice
#SBATCH -N 1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=100G
#SBATCH -t 04:00:00
#SBATCH -o /home/hice1/wsun377/Desktop/cs8803drl/docs/experiments/artifacts/slurm-logs/soccer-exp-041B-pbrs-on-036D150-%j.out

set -euo pipefail

cd /home/hice1/wsun377/Desktop/cs8803drl

# Dynamic port offset (pattern from 036D / 038 / 039 lanes).
PORT_SEED=${PORT_SEED:-${SLURM_JOB_ID:-$$}}
PORT_OFFSET=$(( (PORT_SEED % 20) * 100 ))

PYTHON_BIN=/home/hice1/wsun377/.venvs/soccertwos_h100/bin/python

export PYTHONPATH=$PWD${PYTHONPATH:+:$PYTHONPATH}
export QUIET_CONSOLE=${QUIET_CONSOLE:-0}

# Preserve resume override before scratch-mode unset (pattern from 031B fix).
_RESTORE_OVERRIDE="${RESTORE_CHECKPOINT:-}"
unset RESTORE_CHECKPOINT
unset TEAMMATE_CHECKPOINT
unset TEAMMATE_BASE_CHECKPOINT
unset BC_WARMSTART_CHECKPOINT
[[ -n "$_RESTORE_OVERRIDE" ]] && export RESTORE_CHECKPOINT="$_RESTORE_OVERRIDE"

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1

# Stage 2 base: warm-start from 036D@150 (NOT 029B@190 — 041 is a step beyond 036D)
export WARMSTART_CHECKPOINT=${WARMSTART_CHECKPOINT:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/PPO_mappo_036D_stable_learned_reward_on_029B190_512x512_20260418_124107/MAPPOVsBaselineTrainer_Soccer_72c1c_00000_0_2026-04-18_12-41-29/checkpoint_000150/checkpoint-150}

# Keep 036D's learned reward (the "double shaping" half of the experiment)
export LEARNED_REWARD_MODEL_PATH=${LEARNED_REWARD_MODEL_PATH:-/home/hice1/wsun377/Desktop/cs8803drl/ray_results/reward_models/036_stage2/reward_model.pt}
export LEARNED_REWARD_SHAPING_WEIGHT=${LEARNED_REWARD_SHAPING_WEIGHT:-0.003}
export LEARNED_REWARD_WARMUP_STEPS=${LEARNED_REWARD_WARMUP_STEPS:-0}   # already past warmup since 036D@150 is 150 iter in
export LEARNED_REWARD_APPLY_TO_TEAM1=${LEARNED_REWARD_APPLY_TO_TEAM1:-0}

export RUN_NAME=${RUN_NAME:-041B_mappo_pbrs_on_036D150_512x512_$(date +%Y%m%d_%H%M%S)}
export NUM_GPUS=${NUM_GPUS:-1}
export NUM_WORKERS=${NUM_WORKERS:-8}
export NUM_ENVS_PER_WORKER=${NUM_ENVS_PER_WORKER:-5}
export FCNET_HIDDENS=${FCNET_HIDDENS:-512,512}
export ROLLOUT_FRAGMENT_LENGTH=${ROLLOUT_FRAGMENT_LENGTH:-1000}
export NUM_SGD_ITER=${NUM_SGD_ITER:-4}
export SGD_MINIBATCH_SIZE=${SGD_MINIBATCH_SIZE:-2048}
export LR=${LR:-0.0001}
export CLIP_PARAM=${CLIP_PARAM:-0.15}

# Disable field-role binding (same as 036D)
export SHAPING_FIELD_ROLE_BINDING=${SHAPING_FIELD_ROLE_BINDING:-0}

# v2 shaping (same as 029B / 036D — preserve the base reward distribution)
export USE_REWARD_SHAPING=${USE_REWARD_SHAPING:-1}
export SHAPING_TIME_PENALTY=${SHAPING_TIME_PENALTY:-0.001}
export SHAPING_BALL_PROGRESS=${SHAPING_BALL_PROGRESS:-0.01}
export SHAPING_OPP_PROGRESS_PENALTY=${SHAPING_OPP_PROGRESS_PENALTY:-0.01}
export SHAPING_POSSESSION_BONUS=${SHAPING_POSSESSION_BONUS:-0.002}
export SHAPING_POSSESSION_DIST=${SHAPING_POSSESSION_DIST:-1.25}
export SHAPING_PROGRESS_REQUIRES_POSSESSION=${SHAPING_PROGRESS_REQUIRES_POSSESSION:-0}
export SHAPING_DEEP_ZONE_OUTER_THRESHOLD=${SHAPING_DEEP_ZONE_OUTER_THRESHOLD:--8}
export SHAPING_DEEP_ZONE_OUTER_PENALTY=${SHAPING_DEEP_ZONE_OUTER_PENALTY:-0.003}
export SHAPING_DEEP_ZONE_INNER_THRESHOLD=${SHAPING_DEEP_ZONE_INNER_THRESHOLD:--12}
export SHAPING_DEEP_ZONE_INNER_PENALTY=${SHAPING_DEEP_ZONE_INNER_PENALTY:-0.003}

# 041B-specific: ADD goal-proximity PBRS (Stage 2 handoff signal)
# scale=0.005 chosen to be HALF of 026B's 0.01, to soften shock on already-tuned base
export SHAPING_GOAL_PROXIMITY_SCALE=${SHAPING_GOAL_PROXIMITY_SCALE:-0.005}
export SHAPING_GOAL_PROXIMITY_GAMMA=${SHAPING_GOAL_PROXIMITY_GAMMA:-0.99}
export SHAPING_GOAL_CENTER_X=${SHAPING_GOAL_CENTER_X:-15.0}
export SHAPING_GOAL_CENTER_Y=${SHAPING_GOAL_CENTER_Y:-0.0}

# Stage 2 budget (200 iter ~3h, matches 040 design)
export TIMESTEPS_TOTAL=${TIMESTEPS_TOTAL:-8000000}
export MAX_ITERATIONS=${MAX_ITERATIONS:-200}
export TIME_TOTAL_S=${TIME_TOTAL_S:-14400}
export CHECKPOINT_FREQ=${CHECKPOINT_FREQ:-10}

export EVAL_INTERVAL=${EVAL_INTERVAL:-10}
export EVAL_EPISODES=${EVAL_EPISODES:-50}
# Port shelf 63xxx (clear of 036D 59xxx, 038 54xxx, 039 60xxx, 031B 61xxx, 040 series 62xxx)
export EVAL_BASE_PORT=${EVAL_BASE_PORT:-$((63005 + PORT_OFFSET))}
export EVAL_MAX_STEPS=${EVAL_MAX_STEPS:-1500}
export EVAL_OPPONENTS=${EVAL_OPPONENTS:-baseline,random}
export EVAL_TEAM0_MODULE=${EVAL_TEAM0_MODULE:-cs8803drl.deployment.trained_shared_cc_agent}
export EVAL_PYTHON_BIN=${EVAL_PYTHON_BIN:-$PYTHON_BIN}

export BASE_PORT=${BASE_PORT:-$((63105 + PORT_OFFSET))}
export LOG_LEVEL=${LOG_LEVEL:-INFO}
export LOG_SYS_USAGE=${LOG_SYS_USAGE:-0}

$PYTHON_BIN -u -m cs8803drl.training.train_ray_mappo_vs_baseline 2>&1
