{
  "batch_mode": "truncate_episodes",
  "clip_param": 0.2,
  "entropy_coeff": 0.0,
  "env": "Soccer",
  "env_config": {
    "base_port": 64105,
    "flatten_branched": true,
    "multiagent": false,
    "num_envs_per_worker": 1,
    "opponent_mix": {
      "baseline_prob": 1.0
    },
    "reward_shaping": false,
    "single_player": true,
    "variation": "EnvType.team_vs_policy"
  },
  "framework": "torch",
  "gamma": 0.99,
  "lambda": 0.95,
  "log_level": "WARN",
  "log_sys_usage": false,
  "lr": 0.0001,
  "model": {
    "fcnet_activation": "relu",
    "fcnet_hiddens": [
      256,
      128
    ],
    "lstm_cell_size": 128,
    "max_seq_len": 20,
    "use_lstm": true,
    "vf_share_layers": true
  },
  "num_envs_per_worker": 1,
  "num_gpus": 1,
  "num_sgd_iter": 4,
  "num_workers": 24,
  "rollout_fragment_length": 1000,
  "sgd_minibatch_size": 2048,
  "simple_optimizer": true,
  "train_batch_size": 24000
}