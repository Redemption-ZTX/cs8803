{
  "batch_mode": "truncate_episodes",
  "clip_param": 0.2,
  "entropy_coeff": 0.0,
  "env": "Soccer",
  "env_config": {
    "base_port": 63705,
    "multiagent": false,
    "num_envs_per_worker": 5,
    "opponent_mix": {
      "baseline_prob": 1.0
    },
    "reward_shaping": {
      "ball_progress_scale": 0.01,
      "debug_info": false,
      "deep_zone_inner_penalty": 0.003,
      "deep_zone_inner_threshold": -12.0,
      "deep_zone_outer_penalty": 0.003,
      "deep_zone_outer_threshold": -8.0,
      "defensive_survival_bonus": 0.001,
      "defensive_survival_threshold": -2.0,
      "fast_loss_penalty_per_step": 0.01,
      "fast_loss_threshold_steps": 40,
      "opponent_progress_penalty_scale": 0.01,
      "possession_bonus": 0.002,
      "possession_dist": 1.25,
      "progress_requires_possession": false,
      "time_penalty": 0.001
    },
    "variation": "EnvType.team_vs_policy"
  },
  "framework": "torch",
  "gamma": 0.99,
  "lambda": 0.95,
  "log_level": "INFO",
  "log_sys_usage": false,
  "lr": 0.0003,
  "model": {
    "fcnet_activation": "relu",
    "fcnet_hiddens": [
      512,
      512
    ],
    "vf_share_layers": true
  },
  "num_envs_per_worker": 5,
  "num_gpus": 1,
  "num_sgd_iter": 10,
  "num_workers": 8,
  "rollout_fragment_length": 1000,
  "sgd_minibatch_size": 1024,
  "train_batch_size": 40000
}