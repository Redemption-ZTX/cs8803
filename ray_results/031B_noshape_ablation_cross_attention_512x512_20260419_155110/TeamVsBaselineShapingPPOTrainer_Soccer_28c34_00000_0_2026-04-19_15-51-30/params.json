{
  "batch_mode": "truncate_episodes",
  "clip_param": 0.15,
  "entropy_coeff": 0.0,
  "env": "Soccer",
  "env_config": {
    "base_port": 56255,
    "multiagent": false,
    "num_envs_per_worker": 5,
    "opponent_mix": {
      "baseline_prob": 1.0
    },
    "reward_shaping": false,
    "variation": "EnvType.team_vs_policy"
  },
  "framework": "torch",
  "gamma": 0.99,
  "lambda": 0.95,
  "log_level": "INFO",
  "log_sys_usage": false,
  "lr": 0.0001,
  "model": {
    "custom_model": "team_siamese_cross_attention_model",
    "custom_model_config": {
      "attention_head_dim": 64,
      "attention_n_tokens": 4,
      "encoder_hiddens": [
        256,
        256
      ],
      "merge_hiddens": [
        256,
        128
      ]
    },
    "fcnet_activation": "relu",
    "fcnet_hiddens": [
      512,
      512
    ],
    "vf_share_layers": true
  },
  "num_envs_per_worker": 5,
  "num_gpus": 1,
  "num_sgd_iter": 4,
  "num_workers": 8,
  "rollout_fragment_length": 1000,
  "sgd_minibatch_size": 2048,
  "train_batch_size": 40000
}