{
  "batch_mode": "truncate_episodes",
  "clip_param": 0.2,
  "entropy_coeff": 0.0,
  "env": "Soccer",
  "env_config": {
    "base_port": 63505,
    "multiagent": false,
    "num_envs_per_worker": 5,
    "opponent_mix": {
      "baseline_prob": 1.0
    },
    "reward_shaping": {
      "ball_progress_scale": 0.005,
      "debug_info": false,
      "opponent_progress_penalty_scale": 0.0,
      "possession_bonus": 0.001,
      "possession_dist": 1.25,
      "time_penalty": 0.0005
    },
    "variation": "EnvType.team_vs_policy"
  },
  "framework": "torch",
  "gamma": 0.99,
  "lambda": 0.95,
  "log_level": "INFO",
  "log_sys_usage": false,
  "lr": 0.0001,
  "model": {
    "fcnet_activation": "relu",
    "fcnet_hiddens": [
      512,
      512
    ],
    "vf_share_layers": true
  },
  "num_envs_per_worker": 5,
  "num_gpus": 1,
  "num_sgd_iter": 4,
  "num_workers": 8,
  "rollout_fragment_length": 1000,
  "sgd_minibatch_size": 1024,
  "train_batch_size": 40000
}