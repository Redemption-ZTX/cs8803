{
  "batch_mode": "truncate_episodes",
  "clip_param": 0.2,
  "entropy_coeff": 0.0,
  "env": "Soccer",
  "env_config": {
    "flatten_branched": true,
    "multiagent": false,
    "num_envs_per_worker": 5,
    "reward_shaping": true,
    "single_player": true,
    "variation": "EnvType.team_vs_policy"
  },
  "framework": "torch",
  "gamma": 0.99,
  "lambda": 0.95,
  "log_level": "INFO",
  "lr": 0.0003,
  "model": {
    "fcnet_activation": "relu",
    "fcnet_hiddens": [
      512,
      512
    ],
    "vf_share_layers": true
  },
  "num_envs_per_worker": 5,
  "num_gpus": 1,
  "num_sgd_iter": 10,
  "num_workers": 8,
  "rollout_fragment_length": 2000,
  "sgd_minibatch_size": 4096,
  "train_batch_size": 20000
}